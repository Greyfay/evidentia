# All variables below are OPTIONAL. Evidentia compiles dossiers, runs its
# deterministic controls, and emits a full cases.json replay bundle with none
# of these set — the model/graph/external layers only add interpretation,
# explanation, and exploration on top; they never decide a verdict.

# OpenAI Structured Outputs: bilingual terminology normalization, ambiguous
# passage extraction, counter-hypothesis generation, and auditor-facing case
# explanations. Model output must cite existing evidence IDs; unknown IDs are
# rejected. Without this key, cases still compile and publish, just without
# generated narrative explanation text.
OPENAI_API_KEY=

# Model used for the OpenAI Structured Outputs calls above.
OPENAI_MODEL=gpt-4o-mini

# Cognee evidence graph: builds the multi-hop exploration graph (entities +
# typed relationships) shown in the console's evidence graph view. This is an
# exploration aid only — never a source of calculation truth. Without this
# key, the graph view is simply unavailable; case verdicts are unaffected.
COGNEE_LLM_API_KEY=

# Tavily: optional external verification (e.g. corroborating a vendor's
# public existence). Only used when ADMISSIBLE_ENABLE_EXTERNAL=true below.
TAVILY_API_KEY=

# Master switch for external verification via Tavily. Defaults to false: a
# run is never forced offline-incapable, and external calls are opt-in only.
ADMISSIBLE_ENABLE_EXTERNAL=false
