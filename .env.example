# All variables below are OPTIONAL (except EVIDENTIA_SAMPLE_DOSSIER, and only
# for the tests that need it). Evidentia compiles dossiers, runs its
# deterministic controls, and runs the investigation agent with none of these
# set — the model/graph/external layers only add interpretation, planning
# assistance, and exploration on top; they never decide a verdict.

# OpenAI Structured Outputs: bilingual terminology normalization, ambiguous
# passage extraction, and — in the investigation agent — hypothesis
# generation/ranking, next-tool selection, and auditor-facing explanations.
# Model output must cite existing evidence IDs and allow-listed tool names;
# unknown ones are rejected. Without this key, `get_planner()` falls back to
# the DeterministicPlanner (a genuine, LLM-free planner) and cases still
# compile and publish without generated narrative explanation text.
OPENAI_API_KEY=

# Model used for the OpenAI Structured Outputs calls above.
OPENAI_MODEL=gpt-4o-mini

# Maximum seconds for one OpenAI request before deterministic fallback takes over.
OPENAI_TIMEOUT_SECONDS=20

# Cognee cloud investigation memory: base URL of the Cognee REST API used by
# the agent's relationship graph (add_text / cognify / search). Without this
# (or COGNEE_API_KEY, or `httpx` installed), the agent falls back to the
# local, fully-functional in-memory graph; investigations run identically,
# just without the cloud mirror.
COGNEE_API_URL=

# Cognee tenant id, sent as the X-Tenant-Id header on every cloud call.
COGNEE_TENANT_ID=

# Cognee user id for the investigation memory dataset.
COGNEE_USER_ID=

# Cognee cloud API key, sent as the X-Api-Key header. Required (with
# COGNEE_API_URL) for the cloud memory mirror to activate at all.
COGNEE_API_KEY=

# Tavily: optional external verification (e.g. corroborating a vendor's
# public existence). Only used when ADMISSIBLE_ENABLE_EXTERNAL=true below.
TAVILY_API_KEY=

# Master switch for external verification via Tavily. Defaults to false: a
# run is never forced offline-incapable, and external calls are opt-in only.
ADMISSIBLE_ENABLE_EXTERNAL=false

# Path to a real sample dossier directory. Only needed to run the
# sample-dossier regression suite and the mutation-testing suite (pytest
# skips both without it); every other test runs fully offline with no
# environment variables set at all.
EVIDENTIA_SAMPLE_DOSSIER=
